<Window x:Class="NMSTestClientGUI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:NMSTestClientGUI"
        mc:Ignorable="d"
        Title="Advanced GDA Network Model Tool" Height="550" Width="850">
    <Window.Background>
        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#1F2937" Offset="0"/>
            <GradientStop Color="#111827" Offset="1"/>
        </LinearGradientBrush>
    </Window.Background>

    <Window.Resources>
        <Style TargetType="TextBox">
            <Setter Property="Margin" Value="0,0,0,10"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="Padding" Value="6"/>
            <Setter Property="Background" Value="#111827"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#374151"/>
        </Style>

        <Style TargetType="Button">
            <Setter Property="Height" Value="34"/>
            <Setter Property="Width" Value="200"/>
            <Setter Property="Margin" Value="0,5,0,10"/>
            <Setter Property="Background" Value="#2563EB"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
        </Style>

        <Style TargetType="RichTextBox">
            <Setter Property="Background" Value="#0F172A"/>
            <Setter Property="Foreground" Value="LightBlue"/>
            <Setter Property="VerticalScrollBarVisibility" Value="Auto"/>
            <Setter Property="Margin" Value="0,10,0,0"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>

        <Style TargetType="Label">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
    </Window.Resources>

    <Grid Margin="15">
        <TabControl Background="#020617" BorderBrush="#374151">
            <TabItem Header="GetValues">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <StackPanel>
                        <Label Content="Global ID (Hex format, npr. 0x0000000100000001):" HorizontalAlignment="Center"/>
                        <TextBox x:Name="TbGetValuesGid"/>
                        <Button x:Name="BtnGetValues" Content="Get Values" Click="BtnGetValues_Click" HorizontalAlignment="Center"/>
                    </StackPanel>
                    <RichTextBox x:Name="RtbGetValues" Grid.Row="1"/>
                </Grid>
            </TabItem>

            <TabItem Header="GetExtentValues">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <StackPanel>
                        <Label Content="ModelCode (npr. ACLINESEGMENT):" HorizontalAlignment="Center"/>
                        <TextBox x:Name="TbExtentModelCode"/>
                        <Button x:Name="BtnGetExtent" Content="Get Extent" Click="BtnGetExtent_Click" HorizontalAlignment="Center"/>
                    </StackPanel>
                    <RichTextBox x:Name="RtbExtentValues" Grid.Row="1"/>
                </Grid>
            </TabItem>

            <TabItem Header="GetRelatedValues">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <StackPanel HorizontalAlignment="Center">
                        <Label Content="Source GID:" HorizontalAlignment="Center"/>
                        <TextBox x:Name="TbSourceGid"/>
                        <Label Content="Association Property (Reference/Vector):"/>
                        <TextBox x:Name="TbAssociationProperty"/>
                        <Label Content="Association Type (Target Type):" HorizontalAlignment="Center"/>
                        <TextBox x:Name="TbAssociationType"/>
                        <Button x:Name="BtnGetRelated" Content="Get Related" Click="BtnGetRelated_Click" HorizontalAlignment="Center"/>
                    </StackPanel>
                    <RichTextBox x:Name="RtbRelatedValues" Grid.Row="1"/>
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</Window>