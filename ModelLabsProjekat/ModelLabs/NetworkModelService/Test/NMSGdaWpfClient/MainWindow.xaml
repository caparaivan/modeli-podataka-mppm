<Window x:Class="FTN.Services.NetworkModelService.WpfClient.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="NMS GDA WPF Klijent" Height="700" Width="1100" MinHeight="600" MinWidth="1000">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Čitanje podataka preko prve 3 GDA metode (GetValues, GetExtentValues, GetRelatedValues)" FontWeight="Bold" Margin="0,0,0,12" />

        <GroupBox Grid.Row="1" Header="GDA pozivi" Margin="0,0,0,12">
            <Grid Margin="10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Margin="0,0,10,0">
                    <TextBlock Text="GetValues" FontWeight="SemiBold" Margin="0,0,0,8"/>
                    <TextBlock Text="Global ID (decimal ili 0x...)"/>
                    <TextBox Name="GetValuesGidTextBox" Margin="0,4,0,8" Text="0x0005000000000001"/>
                    <Button Content="Pozovi GetValues" Click="GetValues_Click" Padding="10,4"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Margin="10,0">
                    <TextBlock Text="GetExtentValues" FontWeight="SemiBold" Margin="0,0,0,8"/>
                    <TextBlock Text="Tip (ModelCode klase)"/>
                    <ComboBox Name="ExtentTypeComboBox" Margin="0,4,0,8" MinWidth="220"/>
                    <Button Content="Pozovi GetExtentValues" Click="GetExtentValues_Click" Padding="10,4"/>
                </StackPanel>

                <StackPanel Grid.Column="2" Margin="10,0,0,0">
                    <TextBlock Text="GetRelatedValues" FontWeight="SemiBold" Margin="0,0,0,8"/>
                    <TextBlock Text="Source GID"/>
                    <TextBox Name="RelatedSourceTextBox" Margin="0,4,0,6" Text="0x0005000000000001"/>
                    <TextBlock Text="PropertyId"/>
                    <ComboBox Name="RelatedPropertyComboBox" Margin="0,4,0,6"/>
                    <TextBlock Text="Type"/>
                    <ComboBox Name="RelatedTypeComboBox" Margin="0,4,0,6"/>
                    <CheckBox Name="InverseCheckBox" Content="Inverse" Margin="0,0,0,8"/>
                    <Button Content="Pozovi GetRelatedValues" Click="GetRelatedValues_Click" Padding="10,4"/>
                </StackPanel>
            </Grid>
        </GroupBox>

        <GroupBox Grid.Row="2" Header="Primer za višu ocenu" Margin="0,0,0,12">
            <DockPanel Margin="10">
                <TextBlock DockPanel.Dock="Left" VerticalAlignment="Center" Text="Pronađi sve Terminal-e vezane za ACLineSegment sa najvećim GID-om." />
                <Button DockPanel.Dock="Right" Content="Pokreni primer" Padding="10,4" Click="RunAdvancedQuery_Click"/>
            </DockPanel>
        </GroupBox>

        <GroupBox Grid.Row="3" Header="Rezultat">
            <TextBox Name="OutputTextBox"
                     Margin="10"
                     FontFamily="Consolas"
                     VerticalScrollBarVisibility="Auto"
                     HorizontalScrollBarVisibility="Auto"
                     TextWrapping="NoWrap"
                     AcceptsReturn="True"
                     IsReadOnly="True"/>
        </GroupBox>
    </Grid>
</Window>
